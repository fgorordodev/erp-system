# Application
NODE_ENV=development

# Backend
BACKEND_PORT=3000
FRONTEND_URL=http://localhost:5173

# Database / Docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=erp_system
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_system

# JWT
# Generate each secret independently, for example: openssl rand -hex 64
JWT_ACCESS_SECRET=replace-with-128-character-hex-secret
JWT_REFRESH_SECRET=replace-with-another-128-character-hex-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AES-256-GCM
# Must contain exactly 64 hexadecimal characters: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-character-hex-key

# Development seed administrator
SEED_ADMIN_EMAIL=admin@erp.local
SEED_ADMIN_PASSWORD=change-this-development-password
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Administrator
