{
  "info": {
    "_postman_id": "6d7f0d7c-erp-system",
    "name": "ERP System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "adminEmail",
      "value": "admin@erp.local"
    },
    {
      "key": "adminPassword",
      "value": "Admin123!"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if(pm.response.code===200){",
                  "const r=pm.response.json();",
                  "const t=r?.data?.accessToken||r?.accessToken;",
                  "if(t) pm.collectionVariables.set('accessToken',t);",
                  "]}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\":\"{{adminEmail}}\",\n  \"password\":\"{{adminPassword}}\",\n  \"rememberMe\":false\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\":\"john@example.com\",\n  \"password\":\"Password123!\",\n  \"firstName\":\"John\",\n  \"lastName\":\"Doe\",\n  \"roleId\":\"<ROLE_ID>\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\":\"Updated\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    }
  ]
}
