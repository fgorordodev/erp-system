{
  "info": {
    "_postman_id": "b3f3f5dd-4f35-4e7f-a4f7-erp-system-api",
    "name": "ERP System API",
    "description": "Postman collection for the ERP System NestJS API. Current routes: health, authentication login, and users CRUD.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "admin@erp.local",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "Admin123!",
      "type": "string"
    },
    {
      "key": "testUserEmail",
      "value": "postman.user@erp.local",
      "type": "string"
    },
    {
      "key": "testUserPassword",
      "value": "Password123!",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Health check",
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Response is JSON\", function () { pm.response.to.be.json; });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Authentication endpoints. Login is included for the current AuthModule implementation.",
      "item": [
        {
          "name": "Login with valid credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login with valid credentials",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"rememberMe\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is successful\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const json = pm.response.json();",
                  "const data = json.data ?? json;",
                  "if (data.accessToken) { pm.collectionVariables.set(\"accessToken\", data.accessToken); }",
                  "if (data.user?.id) { pm.collectionVariables.set(\"userId\", data.user.id); }",
                  "if (data.id) { pm.collectionVariables.set(\"userId\", data.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject invalid credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Reject invalid credentials",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"unknown@erp.local\",\n  \"password\": \"IncorrectPassword\",\n  \"rememberMe\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 401\", function () { pm.response.to.have.status(401); });",
                  "const json = pm.response.json();",
                  "const error = json.error ?? json;",
                  "pm.test(\"Uses generic credential error\", function () { pm.expect(error.code).to.eql(\"INVALID_CREDENTIALS\"); });"
                ]
              }
            }
          ]
        }
      ]
    },
